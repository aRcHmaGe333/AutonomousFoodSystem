{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Universal Recipe Compiler (URC) Schema",
  "type": "object",
  "required": ["schemaVersion","id","name","servings","ingredients","steps"],
  "properties": {
    "schemaVersion": {"type":"string"},
    "id": {"type":"string"},
    "name": {"type":"string"},
    "description": {"type":"string"},
    "tags": {"type":"array","items":{"type":"string"}},
    "servings": {"type":"number"},
    "ingredients": {
      "type":"array",
      "items": {
        "type":"object",
        "required":["id","name"],
        "properties":{
          "id":{"type":"string"},
          "name":{"type":"string"},
          "forms":{"type":"array","items":{"type":"string"}},
          "default_quantity":{"type":"object","properties":{"value":{"type":"number"},"unit":{"type":"string"}}}
        }
      }
    },
    "equipment": {"type":"array","items":{"type":"string"}},
    "steps": {
      "type":"array",
      "items":{
        "type":"object",
        "required":["id","action"],
        "properties":{
          "id":{"type":"string"},
          "action":{"type":"string"},
          "description":{"type":"string"},
          "parameters":{"type":"object"},
          "inputs":{"type":"array","items":{"type":"object"}},
          "outputs":{"type":"array","items":{"type":"object"}},
          "requiredSensors":{"type":"array","items":{"type":"string"}},
          "checks":{"type":"array","items":{"type":"object"}},
          "contingency":{"type":"object"},
          "parallelizable":{"type":"boolean"}
        }
      }
    },
    "sensoryGoals":{"type":"object"},
    "nutrition":{"type":"object"},
    "safety":{"type":"object"}
  }
}
